# Environment Variables Configuration

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/civil_defense_db

# Security Configuration
SECRET_KEY=your-secret-key-change-in-production-1234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-1234567890

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# Application Settings
DEBUG=False
